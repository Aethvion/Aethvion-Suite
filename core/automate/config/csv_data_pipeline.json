{
  "name": "CSV Data Pipeline",
  "description": "Paste CSV text, parse it into structured rows, filter them, and display the results.",
  "tags": ["data", "csv", "beginner"],
  "nodes": [
    {
      "id": "ex_t1",
      "type": "trigger.manual",
      "label": "Run",
      "x": 60,
      "y": 100,
      "properties": { "name": "Run" }
    },
    {
      "id": "ex_n1",
      "type": "input.text",
      "label": "CSV Input",
      "x": 60,
      "y": 300,
      "properties": {
        "value": "name,age,city\nAlice,30,New York\nBob,25,Los Angeles\nCarla,35,New York\nDave,28,Chicago"
      }
    },
    {
      "id": "ex_n2",
      "type": "data.csv_parse",
      "label": "Parse CSV",
      "x": 380,
      "y": 180,
      "properties": {
        "delimiter": ",",
        "has_header": true,
        "output_as": "objects",
        "skip_empty_rows": true
      }
    },
    {
      "id": "ex_n3",
      "type": "data.filter",
      "label": "New York Only",
      "x": 680,
      "y": 180,
      "properties": {
        "expression": "item.get('city') == 'New York'"
      }
    },
    {
      "id": "ex_n4",
      "type": "output.display",
      "label": "Results",
      "x": 980,
      "y": 180,
      "properties": {}
    }
  ],
  "connections": [
    {
      "id": "ex_c0",
      "sourceNodeId": "ex_t1",
      "sourcePort": "trigger",
      "targetNodeId": "ex_n2",
      "targetPort": "__trigger__"
    },
    {
      "id": "ex_c1",
      "sourceNodeId": "ex_n1",
      "sourcePort": "out",
      "targetNodeId": "ex_n2",
      "targetPort": "in"
    },
    {
      "id": "ex_c2",
      "sourceNodeId": "ex_n2",
      "sourcePort": "out",
      "targetNodeId": "ex_n3",
      "targetPort": "in"
    },
    {
      "id": "ex_c3",
      "sourceNodeId": "ex_n3",
      "sourcePort": "match",
      "targetNodeId": "ex_n4",
      "targetPort": "in"
    }
  ]
}
