      "label": "Upload File",
      "x": 60,
      "y": 220,
      "properties": {
        "accept": ".txt,.md,.csv,.json"
      }
    },
    {
      "id": "ex_n2",
      "type": "ai.classify",
      "label": "Classify",
      "x": 360,
      "y": 200,
      "properties": {
        "model": "",
