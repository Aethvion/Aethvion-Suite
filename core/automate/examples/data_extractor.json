        "value": "John Smith (john@example.com) called on March 5, 2024 about invoice #1234 for $499.99."
      }
    },
    {
      "id": "ex_n2",
      "type": "ai.extract_data",
      "label": "Extract Data",
      "x": 420,
      "y": 180,
      "properties": {
        "model": "",
